# Copy to .env and fill in values for local development.
# Do NOT commit a real .env.

# ----------------------------------------------------------------------
# Configure your OAuth 2.1 / OIDC authorization server. Each MCP
# service should have its own application + API so audiences are
# distinct.
# ----------------------------------------------------------------------
OAUTH_ISSUER_URL=https://YOUR_AUTH0_TENANT.us.auth0.com
OAUTH_JWKS_URL=https://YOUR_AUTH0_TENANT.us.auth0.com/.well-known/jwks.json

# Set this to the public URL of this service (e.g. https://gmail-mcp.example.com).
# For Auth0, this must match the API Identifier configured in the Auth0 dashboard.
# In Railway, set it AFTER the first deploy, then redeploy to pick it up.
MCP_RESOURCE_URL=http://localhost:8000

MCP_EXPECTED_SCOPES=
# Auth0 emits standard aud == API identifier, so the default (false) is
# correct. Only set to true if a specific provider quirk forces aud ==
# client_id on DCR-minted tokens.
MCP_ACCEPT_CLIENT_ID_AUD=false
JWKS_CACHE_TTL_SECONDS=300
HTTP_TIMEOUT_SECONDS=10

# ----------------------------------------------------------------------
# Database. Railway injects DATABASE_URL automatically when a Postgres
# add-on is provisioned. Locally, point at a Postgres dev instance.
#
# Use a plain postgresql:// URL (Railway-style postgres:// also works).
# The application normalizes the scheme to postgresql+psycopg:// at
# engine-init and migration-run time so SQLAlchemy binds to psycopg v3
# (the driver we actually ship via pyproject.toml). psycopg2 is NOT a
# dependency. If you set an explicit driver yourself
# (e.g. postgresql+psycopg://...), the URL is passed through unchanged.
# ----------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DB_NAME

# ----------------------------------------------------------------------
# Encryption keys. BOTH ARE REQUIRED.
#
# These are TWO DIFFERENT KEYS. Do NOT set them to the same value.
# Key separation is intentional: one key is for token-at-rest
# encryption (Fernet symmetric), the other is for OAuth state-token
# signing (HMAC-SHA256). Reusing one key for both purposes would
# cross-contaminate trust domains.
#
# Generate fresh values with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Run that command twice and use the two distinct outputs.
# ----------------------------------------------------------------------
ENCRYPTION_KEY=replace-with-fernet-generate-key-output-1
STATE_SIGNING_KEY=replace-with-fernet-generate-key-output-2

# ----------------------------------------------------------------------
# Server runtime
# ----------------------------------------------------------------------
LOG_LEVEL=INFO
PORT=8000

# ----------------------------------------------------------------------
# Google OAuth. Required at config load.
#
# Create an OAuth 2.0 Client ID in Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
# Type: "Web application". Authorized redirect URI must match
# GOOGLE_OAUTH_REDIRECT_URL EXACTLY (Google compares byte-for-byte).
# ----------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-cloud-console-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-cloud-console-client-secret
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8000/oauth2callback

# Whitespace-separated Gmail OAuth scopes. The default below covers
# userinfo (to verify the linked email) plus read-only Gmail. Extend
# if send or draft scopes are later added.
GMAIL_OAUTH_SCOPES=openid email https://www.googleapis.com/auth/gmail.readonly

# ----------------------------------------------------------------------
# Auth0 sub allowlist.
#
# Comma-separated list of Auth0 subs permitted to link Gmail accounts
# and call Gmail tools. Required in production unless
# MCP_ALLOW_ANY_AUTH0_SUB=true. The gate runs on every /mcp request, so
# removing a sub here immediately cuts off Gmail tool access on the
# next request.
# ----------------------------------------------------------------------
MCP_ALLOWED_AUTH0_SUBS=auth0|REPLACE_WITH_OWNER_SUB

# Emergency opt-in. When true, any authenticated sub is permitted AND
# the post-callback confirmation page auto-activates regardless of
# allowlist length. Bypasses the allowlist defense; use only for demo
# or debug and revert afterward.
MCP_ALLOW_ANY_AUTH0_SUB=false
